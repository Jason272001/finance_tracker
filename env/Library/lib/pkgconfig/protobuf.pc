prefix=D:/finance_tracker/env/Library
exec_prefix=D:/finance_tracker/env/Library
libdir=D:/finance_tracker/env/Library/lib
includedir=D:/finance_tracker/env/Library/include

Name: Protocol Buffers
Description: Google's Data Interchange Format
Version: 29.3.0
Requires: abseil_dll utf8_range
Libs: -L${libdir} -lprotobuf 
Cflags: -I${includedir} -DPROTOBUF_USE_DLLS
Conflicts: protobuf-lite
